generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Roles {
  ID_Rol     Int         @id @default(autoincrement())
  Nombre_Rol String      @db.VarChar(50)
  usuarios   Usuarios[]
}

model Empresa {
  ID_Empresa Int          @id @default(autoincrement())
  Nombre     String       @db.VarChar(100)
  Direccion  String?      @db.VarChar(255)
  Correo     String?      @db.VarChar(100)
  Telefono   String?      @db.VarChar(20)
  empleados  Empleados[]
  servicios  Servicios[]
}

model Empleados {
  ID_Empleado      Int                @id @default(autoincrement())
  ID_Empresa       Int
  empresa          Empresa            @relation(fields: [ID_Empresa], references: [ID_Empresa])
  Nombre           String             @db.VarChar(100)
  Telefono         String?            @db.VarChar(20)
  Correo           String?            @db.VarChar(100)
  usuario          Usuarios?
  equipos          Empleado_Equipo[]
  checklist_detalle Checklist_Detalle[]
  puntos           Puntos_Historial[]
  reportes         Reportes[]
}

model Usuarios {
  ID_Usuario    Int       @id @default(autoincrement())
  ID_Empleado   Int?      @unique
  ID_Rol        Int?
  Username      String    @db.VarChar(50)
  Password_Hash String?   @db.VarChar(255)
  FirebaseUID   String?   @unique @db.VarChar(128)
  empleado      Empleados? @relation(fields: [ID_Empleado], references: [ID_Empleado])
  rol           Roles?    @relation(fields: [ID_Rol], references: [ID_Rol])
}

model Equipos {
  ID_Equipo     Int               @id @default(autoincrement())
  Nombre_Equipo String?           @db.VarChar(100)
  Tipo          String?           @db.VarChar(50)
  empleados     Empleado_Equipo[]
  proyectos     Proyectos[]
  reportes      Reportes[]
}

model Empleado_Equipo {
  ID_Equipo   Int
  ID_Empleado Int
  Cargo       String?   @db.VarChar(50)
  equipo      Equipos   @relation(fields: [ID_Equipo], references: [ID_Equipo])
  empleado    Empleados @relation(fields: [ID_Empleado], references: [ID_Empleado])

  @@id([ID_Equipo, ID_Empleado])
}

model Clientes {
  ID_Cliente  Int         @id @default(autoincrement())
  Nombre      String      @db.VarChar(100)
  RazonSocial String?     @db.VarChar(100)
  Correo      String?     @db.VarChar(100)
  Direccion   String?     @db.VarChar(255)
  Telefono    String?     @db.VarChar(20)
  proyectos   Proyectos[]
}

model Servicios {
  ID_Servicio  Int                  @id @default(autoincrement())
  ID_Empresa   Int?
  Tipo         String?              @db.VarChar(50)
  Descripcion  String?              @db.VarChar(190)
  empresa      Empresa?             @relation(fields: [ID_Empresa], references: [ID_Empresa])
  proyectos    Proyectos[]
  checklists   Checklist_Servicio[]
}

model Proyectos {
  ID_Proyecto     Int                @id @default(autoincrement())
  ID_Cliente      Int?
  ID_Servicio     Int?
  ID_Equipo       Int?
  Nombre_Proyecto String             @db.VarChar(150)
  Fecha_Inicio    DateTime?          @db.Date
  Fecha_Fin       DateTime?          @db.Date
  Estado          String?            @db.VarChar(30)
  Ubicacion       String?            @db.VarChar(255)
  Imagen_Url      String?
  cliente         Clientes?          @relation(fields: [ID_Cliente], references: [ID_Cliente])
  servicio        Servicios?         @relation(fields: [ID_Servicio], references: [ID_Servicio])
  equipo          Equipos?           @relation(fields: [ID_Equipo], references: [ID_Equipo])
  reportes        Reportes[]
  checklists      Checklist[]
  puntos          Puntos_Historial[]
}

model Reportes {
  ID_Reporte     Int                @id @default(autoincrement())
  ID_Proyecto    Int?
  ID_Equipo      Int?
  Comentarios    String?
  Evidencias_URL String?
  Fecha_Reporte  DateTime           @default(now())
  estado         String?            @default("Pendiente")
  ID_Empleado    Int?
  proyecto       Proyectos?         @relation(fields: [ID_Proyecto], references: [ID_Proyecto])
  equipo         Equipos?           @relation(fields: [ID_Equipo], references: [ID_Equipo])
  empleado       Empleados?         @relation(fields: [ID_Empleado], references: [ID_Empleado])
}

model Materiales {
  ID_Material      Int                          @id @default(autoincrement())
  Nombre_Material  String?                      @db.VarChar(100)
  Stock_Disponible Int?
  checklist_servicio_detalle Checklist_Servicio_Detalle[]
  checklist_detalle          Checklist_Detalle[]
}

model Checklist_Servicio {
  ID_Checklist_Servicio Int                          @id @default(autoincrement())
  ID_Servicio           Int?
  Nombre                String?                      @db.VarChar(100)
  servicio              Servicios?                   @relation(fields: [ID_Servicio], references: [ID_Servicio])
  detalles              Checklist_Servicio_Detalle[]
}

model Checklist_Servicio_Detalle {
  ID_Checklist_Servicio_Detalle Int                  @id @default(autoincrement())
  ID_Checklist_Servicio         Int?
  ID_Material                   Int?
  Cantidad_Requerida            Int?
  checklist_servicio            Checklist_Servicio?  @relation(fields: [ID_Checklist_Servicio], references: [ID_Checklist_Servicio])
  material                      Materiales?          @relation(fields: [ID_Material], references: [ID_Material])
  checklist_detalle             Checklist_Detalle[]
}

model Checklist {
  ID_Checklist   Int                @id @default(autoincrement())
  ID_Proyecto    Int?
  Fecha_Creacion DateTime           @default(now())
  Estado         String?            @db.VarChar(30)
  proyecto       Proyectos?         @relation(fields: [ID_Proyecto], references: [ID_Proyecto])
  detalles       Checklist_Detalle[]
}

model Checklist_Detalle {
  ID_Checklist_Detalle          Int                         @id @default(autoincrement())
  ID_Checklist                  Int?
  ID_Checklist_Servicio_Detalle Int?
  ID_Material                   Int?
  Cantidad_Requerida            Int?
  Cantidad_Cargada              Int?
  Marcado                       Boolean                     @default(false)
  Fecha_Marcado                 DateTime?
  ID_Empleado                   Int?
  Observaciones                 String?
  checklist                     Checklist?                  @relation(fields: [ID_Checklist], references: [ID_Checklist])
  checklist_servicio_detalle    Checklist_Servicio_Detalle? @relation(fields: [ID_Checklist_Servicio_Detalle], references: [ID_Checklist_Servicio_Detalle])
  material                      Materiales?                 @relation(fields: [ID_Material], references: [ID_Material])
  empleado                      Empleados?                  @relation(fields: [ID_Empleado], references: [ID_Empleado])
}

model Puntos_Historial {
  ID_Punto         Int        @id @default(autoincrement())
  ID_Empleado      Int?
  ID_Proyecto      Int?
  Cantidad_Puntos  Int?
  Fecha_Asignacion DateTime   @default(now())
  Motivo           String?
  empleado         Empleados? @relation(fields: [ID_Empleado], references: [ID_Empleado])
  proyecto         Proyectos? @relation(fields: [ID_Proyecto], references: [ID_Proyecto])
}